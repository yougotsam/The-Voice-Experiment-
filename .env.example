# Assembly AI - Real-time Speech-to-Text
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# LLM Provider (OpenAI-compatible endpoint)
# Groq API key is also used for Groq TTS when TTS_PROVIDER=groq
LLM_API_KEY=your_groq_or_openai_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Eleven Labs - Text-to-Speech (used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Groq TTS settings (used when TTS_PROVIDER=groq)
# Voices: Arista-PlayAI, Fritz-PlayAI, Troy, Hannah, Austin
GROQ_TTS_VOICE=Arista-PlayAI
GROQ_TTS_MODEL=playai-tts

# TTS Provider: elevenlabs | groq | dia2 | csm | piper
#   elevenlabs - Best quality, requires API key (paid)
#   groq       - Fast, uses same Groq API key as LLM (free tier available)
#   dia2       - Free open-source, GPU required, install dia2-voice repo
#   csm        - Free open-source, GPU required, uses existing CSM-1B model
#   piper      - Free open-source, CPU only, fast but lower quality
TTS_PROVIDER=elevenlabs

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000
