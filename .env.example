# Assembly AI - Real-time Speech-to-Text
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# LLM Provider (OpenAI-compatible endpoint)
# Groq API key is also used for Groq TTS when TTS_PROVIDER=groq
LLM_API_KEY=your_groq_or_openai_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Eleven Labs - Text-to-Speech (used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Google Gemini (for LLM model selector)
GEMINI_API_KEY=your_gemini_api_key_here

# xAI Grok (for LLM model selector and xAI TTS)
XAI_API_KEY=your_xai_api_key_here

# Ollama - Local LLM (Gemma, Llama, Mistral, etc.)
# Start Ollama first: ollama serve && ollama pull gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:4b
OLLAMA_API_KEY=ollama

# Piper - Local Text-to-Speech (no API key needed)
# Install: pip install piper-tts   OR   brew install piper
# Download voices from https://huggingface.co/rhasspy/piper-voices
PIPER_MODELS_DIR=/path/to/your/piper/models
PIPER_VOICE=hal

# Groq TTS settings (used when TTS_PROVIDER=groq)
# Orpheus voices: troy, austin, daniel, autumn, diana, hannah
GROQ_TTS_VOICE=autumn
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english

# TTS Provider: groq | xai | elevenlabs | piper | fallback
#   groq       - Fast, uses same Groq API key as LLM (free tier available)
#   xai        - xAI voices (eve, ara, rex, sal, leo)
#   elevenlabs - High quality streaming, requires API key (paid)
#   piper      - Local TTS, no API key needed
#   fallback   - Smart fallback chain (tries providers in order)
TTS_PROVIDER=fallback

# Fallback chain order (comma-separated, used when TTS_PROVIDER=fallback)
TTS_FALLBACK_CHAIN=groq,xai,elevenlabs

# FireCrawl - Web Search & Scraping (enables research agent)
# Get your key from https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_key_here

# GoHighLevel CRM (Private Integration Token)
# Get your token from GHL Settings > Integrations > Private Integrations
GHL_API_KEY=your_ghl_private_integration_token_here
GHL_LOCATION_ID=your_ghl_location_id_here
# Webhook secret for verifying inbound GHL webhooks (optional but recommended)
# Set this to a random string, then append ?secret=<value> to your GHL webhook URL
GHL_WEBHOOK_SECRET=

# Redis (optional - enables cross-session memory persistence)
# Install Redis: brew install redis && brew services start redis
# Or use Docker: docker run -d -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend (Next.js) — set these for non-localhost deployments
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_URL=http://localhost:8000
